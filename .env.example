# GSRS RAG Gateway - Environment Configuration

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Database URL - scheme determines backend automatically:
# - PostgreSQL: postgresql://user:pass@host:port/dbname
# - ChromaDB: chroma://./chroma_data/chunks

# For ChromaDB (Development/Testing - Default):
DATABASE_URL=chroma://./chroma_data/chunks

# For PostgreSQL (Production - uncomment and set):
# DATABASE_URL=postgresql://gsrs:your_secure_password@localhost:5432/gsrs_rag

# =============================================================================
# EMBEDDING API CONFIGURATION
# =============================================================================
# Works with OpenAI, Azure OpenAI, Ollama, and OpenAI-compatible APIs

# OpenAI (Production):
EMBEDDING_API_KEY=sk-your-api-key-here
EMBEDDING_URL=https://api.openai.com/v1/embeddings
EMBEDDING_VERIFY_SSL=true

# Azure OpenAI (uncomment and configure for Azure):
# EMBEDDING_API_KEY=your-azure-key
# EMBEDDING_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment/embeddings?api-version=2024-02-01
# EMBEDDING_VERIFY_SSL=false

# Ollama (Local/Development - uncomment for local embeddings):
# EMBEDDING_API_KEY=ollama
# EMBEDDING_URL=http://host.docker.internal:11434/api/embed

# =============================================================================
# EMBEDDING MODEL CONFIGURATION
# =============================================================================
# OpenAI Models:
#   - text-embedding-3-small (1536 dim, recommended)
#   - text-embedding-3-large (3072 dim, highest quality)
#   - text-embedding-ada-002 (1536 dim, legacy)

# Ollama Models:
#   - nomic-embed-text-v2-moe (768 dim, lightweight)
#   - mxbai-embed-large (1024 dim, high quality)
#   - qwen3-embedding:latest (2000 dim, high quality)
#   - all-minilm (384 dim, smallest)

EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# =============================================================================
# CHUNKING CONFIGURATION
# =============================================================================
# Optional overrides for SubstanceChunker ordering (comma-separated values)
# CHUNKER_IDENTIFIERS_ORDER=FDA UNII,UNII,SMS_ID,SMSID,ASK,ASKP,SVGID,EVMPD,xEVMPD,CAS,DRUG BANK,RXCUI,CHEMBL,PUBCHEM
# CHUNKER_CLASSIFICATIONS_ORDER=WHO-ATC,WHO-VATC,NCI_THESAURUS,EMA ASSESSMENT REPORTS,WHO-ESSENTIAL MEDICINES LIST,NDF-RT,LIVERTOX,FDA ORPHAN DRUG,EU-ORPHAN DRUG

# For Ollama (uncomment for local embeddings):
# EMBEDDING_MODEL=nomic-embed-text-v2-moe
# EMBEDDING_DIMENSION=768

# =============================================================================
# AUTHENTICATION CONFIGURATION (HTTP Basic Auth)
# =============================================================================
# Change these in production!
API_USERNAME=admin
API_PASSWORD=admin123

# =============================================================================
# API CONFIGURATION
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000

# Vector Search Configuration
DEFAULT_TOP_K=5

# =============================================================================
# OPEN WEBUI CONFIGURATION (Optional, for Ollama integration)
# =============================================================================
# Ollama base URL (for Open WebUI)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# WebUI secret key (change in production!)
WEBUI_SECRET_KEY=gsrs_secret_key_change_me_in_production

# Enable authentication in WebUI
WEBUI_AUTH=true

